{
  "name": "mtts-js",
  "version": "1.0.0",
  "description": "Local, cross-platform Text-to-Speech (TTS) desktop application",
  "main": "./out/main/main.js",
  "type": "module",
  "scripts": {
    "build": "tsc && electron-vite build",
    "start": "node dist/index.js",
    "dev": "electron-vite dev -- --ozone-platform=x11",
    "preview": "electron-vite preview -- --ozone-platform=x11"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@types/node": "^22.19.17",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0",
    "vite": "^7.3.2",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "audic": "^3.0.2",
    "kokoro-js": "^1.2.1",
    "onnxruntime-node": "^1.24.3",
    "tailwindcss": "^4.2.2",
    "wavefile": "^11.0.0"
